{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "运维工具",
    "version": "0.1.5"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "save": true
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "template": "./windows/installer.nsi"
        },
        "wix": {
          "language": "zh-CN"
        }
      },
      "targets": "all",
      "identifier": "com.ipdiagnostic.tool"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "center": true,
        "fullscreen": false,
        "resizable": true,
        "title": "运维工具",
        "width": 880,
        "height": 720,
        "minWidth": 780,
        "minHeight": 680
      }
    ]
  }
}
